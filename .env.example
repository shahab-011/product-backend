# Copy this file to .env and fill in the values.
# On Render: set these in the service's Environment tab.

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (replace with your Atlas URI for production)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nyaya?retryWrites=true&w=majority

# Generate a long random string for production (e.g.: openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Your Netlify frontend URL (no trailing slash)
CLIENT_URL=https://your-app.netlify.app
