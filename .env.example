# Copy this file to .env and fill in the values.
# On Render: set these in the service's Environment tab.

PORT=5000
NODE_ENV=production

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP / nodemailer) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=NyayaAI <noreply@nyaya.ai>

# ── AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── AWS S3 / CloudFront ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=nyayaai-documents
AWS_CLOUDFRONT_URL=https://xxxx.cloudfront.net

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Twilio (SMS) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890

# ── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ───────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Plaid (Bank feeds) ────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Redis (optional — caching & Bull queues) ──────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── URLs ──────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# MongoDB Atlas connection string (replace with your Atlas URI for production)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nyaya?retryWrites=true&w=majority

# Generate a long random string for production (e.g.: openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Your Netlify frontend URL (no trailing slash)
CLIENT_URL=https://your-app.netlify.app
